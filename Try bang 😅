            pcall(function()
                local torso = myChar:FindFirstChild("Torso") or myChar:FindFirstChild("LowerTorso")
                local rootJoint = torso and (torso:FindFirstChild("RootJoint") or myHRP:FindFirstChild("RootJoint"))
                if rootJoint and attachDistance > 0 then
                    local hipThrustAngle = math.rad(sineWave * (forwardBackRange * 15))
                    local jointOffsetZ = -math.abs(sineWave) * (forwardBackRange * 0.2)
                    rootJoint.C0 = CFrame.new(0, 0, jointOffsetZ) * CFrame.Angles((currentModeToRun == "Face Bang" and hipThrustAngle or -hipThrustAngle), 0, 0)
                elseif rootJoint then
                    rootJoint.C0 = CFrame.new()
                end
            end)
            
            pcall(function()
                for _, v in pairs(myChar:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end)
        end) 
    end 
end)
