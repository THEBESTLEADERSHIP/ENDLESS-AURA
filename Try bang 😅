local lastSoundTime = 0
local soundGap = 5

local function stopAllSounds()
    sound1:Stop()
    sound2:Stop()
    sound3:Stop()
end

local function handleAudioForMode(currentMode)
    if soundMuted then 
        stopAllSounds()
        return 
    end
    
    if tick() - lastSoundTime >= soundGap then
        if currentMode == "Normal" then
            if sound2.IsPlaying then sound2:Stop() end
            if sound3.IsPlaying then sound3:Stop() end
            if not sound1.IsPlaying then
                sound1:Play()
                lastSoundTime = tick()
            end
        elseif currentMode == "Face Bang" then
            if sound1.IsPlaying then sound1:Stop() end
            if sound3.IsPlaying then sound3:Stop() end
            if not sound2.IsPlaying then
                sound2:Play()
                lastSoundTime = tick()
            end
        elseif currentMode == "Auto Switch" then
            if sound1.IsPlaying then sound1:Stop() end
            if sound2.IsPlaying then sound2:Stop() end
            if not sound3.IsPlaying then
                sound3:Play()
                lastSoundTime = tick()
            end
        end
    end
end

