-- Dynamic Slider Generator
local function createSlider(minY, labelText, minVal, maxVal, defaultVal, callback)
    local label = Instance.new("TextLabel", mainFrame)
    label.Size = UDim2.new(1, -24, 0, 14)
    label.Position = UDim2.new(0, 12, 0, minY)
    label.Text = labelText .. ": " .. tostring(defaultVal)
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Font = Enum.Font.Code
    label.TextSize = 10
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("TextButton", mainFrame) 
    track.Size = UDim2.new(1, -24, 0, 4)
    track.Position = UDim2.new(0, 12, 0, minY + 16)
    track.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    track.Text = ""
    track.BorderSizePixel = 0

    local fill = Instance.new("Frame", track)
    fill.Size = UDim2.new((defaultVal - minVal)/(maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
    fill.BorderSizePixel = 0

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0, 8, 0, 12)
    knob.Position = UDim2.new((defaultVal - minVal)/(maxVal - minVal), -4, 0.5, -6)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)

    local function updateSliderPosition(inputPositionX)
        local relativeX = math.clamp((inputPositionX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        knob.Position = UDim2.new(relativeX, -4, 0.5, -6)
        fill.Size = UDim2.new(relativeX, 0, 1, 0)
        
        local currentVal = math.floor((minVal + (relativeX * (maxVal - minVal))) * 10) / 10
        label.Text = labelText .. ": " .. tostring(currentVal)
        callback(currentVal)
    end

    local sliderDragging = false
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = true
            updateSliderPosition(input.Position.X) 
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if sliderDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSliderPosition(input.Position.X)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliderDragging = false end
    end)
end

