-- ============================================
-- TITAN ATTACH ENGINE + RANGE LOGIC
-- ============================================
local isAttached = false
local selectedPlayer = nil

local function getOrientationPart(char)
    if not char then return nil end
    return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")[span_3](start_span)[span_3](end_span)
end

local function GetTarget()
    local targetName = targetBox.Text:lower():gsub("%s+", "")
    if targetName == "" then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        local name = p.Name:lower()
        local display = (p.DisplayName or ""):lower()
        if name:find(targetName) or display:find(targetName) then
            return p
        end
    end
    return nil
end

toggleButton.MouseButton1Click:Connect(function()
    if isAttached then
        isAttached = false
        if _G.EndlessAuraStorage.ActiveConnection then _G.EndlessAuraStorage.ActiveConnection:Disconnect() _G.EndlessAuraStorage.ActiveConnection = nil end
        if _G.EndlessAuraStorage.AnimForceConnection then _G.EndlessAuraStorage.AnimForceConnection:Disconnect() _G.EndlessAuraStorage.AnimForceConnection = nil end
        
        pcall(function()
            local char = player.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    for _, track in pairs(hum:GetPlayingAnimationTracks()) do track:Stop() end
                    hum.PlatformStand = false
                end
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then pcall(function() sethiddenproperty(hrp, "PhysicsRepRootPart", nil) end) end[span_4](start_span)[span_4](end_span)
            end
        end)
        
        activeTrack = nil
        toggleButton.Text = "[ FUCK ON ]"
        toggleButton.BackgroundColor3 = Color3.fromRGB(255, 215, 0)
        statusLabel.Text = "● STATUS: READY [TITAN]"
        statusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        selectedPlayer = GetTarget()
        if not selectedPlayer or not selectedPlayer.Character then
            statusLabel.Text = "● ERROR: TARGET NOT FOUND"
            statusLabel.TextColor3 = Color3.fromRGB(255, 50, 50)
            return
        end

        isAttached = true
        toggleButton.Text = "[ FUCK OFF ]"
        toggleButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
        statusLabel.Text = "● STATUS: EXECUTING LOCK"
        statusLabel.TextColor3 = Color3.fromRGB(255, 215, 0)

        local myChar = player.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        local myHumanoid = myChar and myChar:FindFirstChildOfClass("Humanoid")
        if not myHRP or not myHumanoid then return end

        local tChar = selectedPlayer.Character
        local tOrient = getOrientationPart(tChar)[span_5](start_span)[span_5](end_span)

        -- Sabhi random animations ko forcefully suppress karna loop
        _G.EndlessAuraStorage.AnimForceConnection = RunService.Stepped:Connect(function()
            if not isAttached then return end
            pcall(function()
                local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local targetAnimToUse = (targetMode == "Face Bang") and faceBangAnimId or bangAnimId
                    
                    for _, track in pairs(hum:GetPlayingAnimationTracks()) do
                        if track.Animation.AnimationId ~= targetAnimToUse then
                            track:Stop()
                        end
                    end

                    if not activeTrack or activeTrack.Animation.AnimationId ~= targetAnimToUse or not activeTrack.IsPlaying then
                        if activeTrack then pcall(function() activeTrack:Stop() end) end
                        local newAnim = Instance.new("Animation")
                        newAnim.AnimationId = targetAnimToUse
                        activeTrack = hum:LoadAnimation(newAnim)
                        activeTrack.Priority = Enum.AnimationPriority.Action4
                        activeTrack.Looped = true
                        activeTrack:Play()
                    end
                    
                    if activeTrack then
                        activeTrack:AdjustSpeed(speedMultiplier / 5)
                    end
                end
            end)
        end)

        -- TITAN POSITION & PHYSICS LOCK (Includes STROKE_RANGE check)
        _G.EndlessAuraStorage.ActiveConnection = RunService.Heartbeat:Connect(function()
            if not isAttached or not selectedPlayer then return end
            
            local currentTargetChar = selectedPlayer.Character
            if not currentTargetChar then return end
            tOrient = getOrientationPart(currentTargetChar)[span_6](start_span)[span_6](end_span)
            if not tOrient then return end

            myChar = player.Character
            myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
            myHumanoid = myChar and myChar:FindFirstChildOfClass("Humanoid")
            if not myHRP or not myHumanoid then return end

            myHumanoid.PlatformStand = true

            -- DYNAMIC STROKE LOGIC: ATTACH_DISTANCE/GAP pe condition set ki hai
            local finalOffsetZ = attachDistance
            if attachDistance > 0 then
                -- Agar GAP zero se bada hai, tabhi dynamic STROKE_RANGE loop swing run karega
                local timeFactor = tick() * speedMultiplier
                local sineWave = math.sin(timeFactor)
                finalOffsetZ = attachDistance + (math.abs(sineWave) * strokeRange)
            end

            -- TITAN physics translation (Welded Offset)[span_7](start_span)[span_7](end_span)
            local targetCFrame
            if targetMode == "Face Bang" then
                local head = currentTargetChar:FindFirstChild("Head") or tOrient
                targetCFrame = head.CFrame * CFrame.new(0, -0.2, -finalOffsetZ) * CFrame.Angles(0, math.pi, 0)
            else
                targetCFrame = tOrient.CFrame * CFrame.new(0, 0, finalOffsetZ)
            end

            -- Physics translation[span_8](start_span)[span_8](end_span)
            pcall(function() sethiddenproperty(myHRP, "PhysicsRepRootPart", tOrient) end)[span_9](start_span)[span_9](end_span)
            myHRP.CFrame = targetCFrame
            myHRP.Velocity = Vector3.new()
            myHRP.AssemblyLinearVelocity = Vector3.new()
            myHRP.AssemblyAngularVelocity = Vector3.new()
            myHRP.RotVelocity = Vector3.new()

            pcall(function()
                for _, v in pairs(myChar:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end)
        end)
    end
end)
