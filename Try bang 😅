-- ====================================================================
-- // ADVANCED VIDEO-SYNC PHYSICS ENGINE (0.001s HIGHSPEED CONDUIT) // --
-- ====================================================================
toggleButton.MouseButton1Click:Connect(function() 
    if isAttached then 
        isAttached = false 
        if _G.EndlessAuraStorage.ActiveConnection then _G.EndlessAuraStorage.ActiveConnection:Disconnect() _G.EndlessAuraStorage.ActiveConnection = nil end 
        if _G.EndlessAuraStorage.ActiveConnection2 then _G.EndlessAuraStorage.ActiveConnection2:Disconnect() _G.EndlessAuraStorage.ActiveConnection2 = nil end 
        if _G.EndlessAuraStorage.PlatformPart then _G.EndlessAuraStorage.PlatformPart:Destroy() _G.EndlessAuraStorage.PlatformPart = nil end 
        
        if activeTrack then activeTrack:Stop() activeTrack = nil end
        stopAllSounds()
        
        toggleButton.Text = "🚀 START ATTACK" 
        toggleButton.TextColor3 = Color3.new(0, 1, 0.5) 
        
        pcall(function()
            local char = player.Character
            local torso = char:FindFirstChild("Torso") or char:FindFirstChild("LowerTorso")
            local rootJoint = torso and (torso:FindFirstChild("RootJoint") or char.HumanoidRootPart:FindFirstChild("RootJoint"))
            if rootJoint then rootJoint.C0 = CFrame.new() end
            if char:FindFirstChild("Humanoid") then char.Humanoid.PlatformStand = false end
        end)
    elseif #selectedPlayers > 0 then 
        isAttached = true 
        toggleButton.Text = "🛑 STOP" 
        toggleButton.TextColor3 = Color3.new(1, 0, 0) 
        lastTargetSwitchTime = tick()
        lastSoundTime = 0 
        currentTargetIndex = 1
        selectedPlayer = selectedPlayers[currentTargetIndex]
        
        local myChar = player.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        if not animMuted then
            local hum = getHumanoid()
            if hum then
                local anim = Instance.new("Animation")
                anim.AnimationId = bangAnimId
                activeTrack = hum:LoadAnimation(anim)
                activeTrack.Looped = true
                activeTrack:Play()
                activeTrack:AdjustSpeed(speedMultiplier / 5)
            end
        end

        local platform = Instance.new("Part")
        platform.Size = Vector3.new(10, 1, 10) 
        platform.Transparency = 1 
        platform.Anchored = true
        platform.CanCollide = true
        platform.Parent = game.Workspace
        _G.EndlessAuraStorage.PlatformPart = platform

        local function processHighSpeedPhysics()
            if not isAttached or #selectedPlayers == 0 then return end 
            
            -- Cycle targets smoothly (0.1s for extreme response)
            if tick() - lastTargetSwitchTime >= 0.1 or not selectedPlayer then
                lastTargetSwitchTime = tick()
                currentTargetIndex = currentTargetIndex + 1
                if currentTargetIndex > #selectedPlayers then currentTargetIndex = 1 end
                selectedPlayer = selectedPlayers[currentTargetIndex]
            end

            if not selectedPlayer or not selectedPlayer.Character then return end

            local myChar = player.Character
            local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart") 
            local myHumanoid = myChar and myChar:FindFirstChild("Humanoid")
            if not myHRP or not myHumanoid then return end
            
            local targetHRP = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            local targetHead = selectedPlayer.Character:FindFirstChild("Head") 
            if not targetHRP then return end

            handleAudioForMode(targetMode)

            if targetHRP.Position.Y < -60 then
                myHRP.AssemblyLinearVelocity = Vector3.new(0,0,0)
                if platform and platform.Parent then platform.CFrame = myHRP.CFrame * CFrame.new(0, -3.1, 0) end
                return 
            end

            myHumanoid.PlatformStand = true 
            
            -- Sine Calculations based on custom slider multipliers
            local sineWave = math.sin(tick() * speedMultiplier) * forwardBackRange
            
            local targetCFrame
            if targetMode == "Mouth" then
                local basePart = targetHead or targetHRP
                targetCFrame = basePart.CFrame 
                    * CFrame.new(0, fixedUpOffset, -attachDistance - 0.2) 
                    * CFrame.Angles(0, math.pi, 0)
                    + basePart.CFrame.LookVector * (sineWave * 0.7)
            else
                targetCFrame = targetHRP.CFrame 
                    * CFrame.new(0, fixedUpOffset, attachDistance + 0.8 + sineWave) 
                    * CFrame.Angles(math.rad(sineWave * 15), 0, 0)
            end
            
            -- Absolute Coupling via dual simulations pipelines
