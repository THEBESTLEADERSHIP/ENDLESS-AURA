    if shouldPlay then
        if animateScript then animateScript.Disabled = true end
        for _, t in pairs(animator:GetPlayingAnimationTracks()) do
            t:Stop(0.1)
        end

        local success, objects = pcall(function() 
            return game:GetObjects("rbxassetid://" .. customAnimId) 
        end)

        local animation
        if success and objects[1] and objects[1]:IsA("Animation") then
            animation = objects[1]
        else
            animation = Instance.new("Animation")
            animation.AnimationId = "rbxassetid://" .. customAnimId
        end

        customTrack = animator:LoadAnimation(animation)
        customTrack.Priority = Enum.AnimationPriority.Action4
        customTrack.Looped = true
        customTrack:Play()
    else
        if customTrack then
            customTrack:Stop(0.1)
            customTrack = nil
        end
        if animateScript then animateScript.Disabled = false end
    end
end

