-- [ TITAN ATTACH ENGINE - Triple-Lock Attachment System ]
local TitanAttach = {}
TitanAttach.__index = TitanAttach

function TitanAttach.new()
    local self = setmetatable({
        active = false,
        target = nil,
        connections = {},
        animTrack = nil,
        animId = nil,
        freezeTime = nil,
        offset = CFrame.new(0, 0, -5),
        lookAtTarget = false,
        useHead = false,
        platformStand = false,
        antiCheatBypass = false,
        attachPart = nil, -- "UpperTorso", "Head", "HumanoidRootPart"
        speed = 1,
        orbitAngle = 0,
        customUpdate = nil, -- function(targetBody, root)
    }, TitanAttach)

    return self
end

function TitanAttach:getTargetBody()
    if not self.target or not self.target.Character then return nil end
    local char = self.target.Character
    if self.attachPart == "Head" then
        return char:FindFirstChild("Head")
    elseif self.attachPart == "UpperTorso" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
end

function TitanAttach:getLocalRoot()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

function TitanAttach:getLocalHumanoid()
    local char = player.Character
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid")
end

function TitanAttach:clearConnections()
    for _, conn in ipairs(self.connections) do
        if conn then pcall(conn.Disconnect, conn) end
    end
    self.connections = {}
end

function TitanAttach:stopAnim()
    if self.animTrack then
        pcall(self.animTrack.Stop, self.animTrack)
        self.animTrack = nil
    end
    local char = player.Character
    if char and char:FindFirstChild("Animate") then
        char.Animate.Disabled = false
    end
    local hum = self:getLocalHumanoid()
    if hum and self.platformStand then
        hum.PlatformStand = false
    end
    if self.antiCheatBypass then
        pcall(function()
            workspace.FallenPartsDestroyHeight = -500
        end)
        self.antiCheatBypass = false
    end
end

function TitanAttach:playAnim(animId, freezeTime, speed)
    local hum = self:getLocalHumanoid()
    if not hum then return end
    
    local char = player.Character
    if char and char:FindFirstChild("Animate") then
        char.Animate.Disabled = true
    end
    
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. animId
    self.animTrack = hum:LoadAnimation(anim)
    self.animTrack.Priority = Enum.AnimationPriority.Action4
    self.animTrack.Looped = true
    self.animTrack:Play()
    
    if freezeTime then
        self.animTrack.TimePosition = freezeTime
        self.animTrack:AdjustSpeed(speed or 0)
    elseif speed then
        self.animTrack:AdjustSpeed(speed)
    end
    
    if self.platformStand then
        hum.PlatformStand = true
    end
    
    if self.antiCheatBypass then
        pcall(function()
            workspace.FallenPartsDestroyHeight = 0/0
        end)
    end
end

function TitanAttach:start()
    if self.active then return end
    self.active = true
    
    local function attachLoop()
        if not self.active then return end
        local targetBody = self:getTargetBody()
        local root = self:getLocalRoot()
        local hum = self:getLocalHumanoid()
        
        if not targetBody or not targetBody.Parent or not root then
            self:stop()
            return
        end
        
        -- Custom update function (for orbit, dynamic distance, etc)
        if self.customUpdate then
            self.customUpdate(targetBody, root, hum)
            return
        end
        
        -- Standard attachment
        local targetCF = targetBody.CFrame
        local offsetCF = targetCF * self.offset
        
        -- Look at target
        if self.lookAtTarget then
            local lookPos = Vector3.new(targetCF.Position.X, offsetCF.Position.Y, targetCF.Position.Z)
            if (lookPos - offsetCF.Position).Magnitude > 0.1 then
                offsetCF = CFrame.lookAt(offsetCF.Position, lookPos)
            end
        end
        
        -- Physics reparent for anti-void
        pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", targetBody) end)
        
        root.CFrame = offsetCF
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
        root.RotVelocity = Vector3.zero
        
        if hum and self.platformStand then
            hum.Sit = true
            hum.PlatformStand = true
        end
        
        -- Freeze animation at specific time
        if self.freezeTime and self.animTrack then
            self.animTrack.TimePosition = self.freezeTime
            if not self.animTrack.IsPlaying then
                self.animTrack:Play()
                self.animTrack:AdjustSpeed(0)
            end
        end
    end
    
    -- Triple-lock: PreSimulation, PostSimulation, RenderStepped
    table.insert(self.connections, RunService.PreSimulation:Connect(attachLoop))
    table.insert(self.connections, RunService.PostSimulation:Connect(attachLoop))
    table.insert(self.connections, RunService.RenderStepped:Connect(attachLoop))
end

function TitanAttach:stop()
    if not self.active then return end
    self.active = false
    
    self:clearConnections()
    self:stopAnim()
    
    local root = self:getLocalRoot()
    if root then
        pcall(function() sethiddenproperty(root, "PhysicsRepRootPart", nil) end)
        root.AssemblyLinearVelocity = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end
    
    local hum = self:getLocalHumanoid()
    if hum then
        hum.Sit = false
        hum.PlatformStand = false
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
    end
end

