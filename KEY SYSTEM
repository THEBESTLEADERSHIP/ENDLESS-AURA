-- SHAKE FUNCTION
-- ==========================================
local canShake = true

local function shakeUI()
    if not canShake then return end
    canShake = false
    
    playS(WRONG_SOUND_ID) --
    
    local originalPos = MainFrame.Position
    local offset = 8
    
    local shake1 = TweenService:Create(MainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Position = UDim2.new(0.5, offset, 0.5, 0)})
    local shake2 = TweenService:Create(MainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Position = UDim2.new(0.5, -offset, 0.5, 0)})
    local shake3 = TweenService:Create(MainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Position = UDim2.new(0.5, offset/2, 0.5, 0)})
    local shake4 = TweenService:Create(MainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Position = UDim2.new(0.5, -offset/2, 0.5, 0)})
    local back = TweenService:Create(MainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Position = originalPos})
    
    shake1:Play()
    shake1.Completed:Connect(function()
        shake2:Play()
        shake2.Completed:Connect(function()
            shake3:Play()
            shake3.Completed:Connect(function()
                shake4:Play()
                shake4.Completed:Connect(function()
                    back:Play()
                    back.Completed:Connect(function()
                        task.wait(SHAKE_COOLDOWN)
                        canShake = true
                    end)
                end)
            end)
        end)
    end)
end

-- ==========================================
-- FADE OUT ENGINE
-- ==========================================
local function fadeOutAndDestroy(halfwayCallback, continueAfterCallback)
    local duration = 1.0
    local easeStyle = Enum.EasingStyle.Sine
    local easeDir = Enum.EasingDirection.InOut

    local blurTweenOut = TweenService:Create(
        blurEffect,
        TweenInfo.new(duration, easeStyle, easeDir),
        {Size = 0}
    )
    blurTweenOut:Play()

    local fadeInfo = TweenInfo.new(duration, easeStyle, easeDir)
    for _, item in pairs(sg:GetDescendants()) do
        if item:IsA("Frame") and item.BackgroundTransparency < 1 then
            TweenService:Create(item, fadeInfo, {BackgroundTransparency = 1}):Play()
        elseif item:IsA("TextLabel") or item:IsA("TextBox") or item:IsA("TextButton") then
            TweenService:Create(item, fadeInfo, {TextTransparency = 1}):Play()
        elseif item:IsA("UIStroke") then
            TweenService:Create(item, fadeInfo, {Transparency = 1}):Play()
        elseif item:IsA("ImageLabel") then
            TweenService:Create(item, fadeInfo, {ImageTransparency = 1}):Play()
        end
    end

    local scaleDown = TweenService:Create(
        UIScale,
        TweenInfo.new(duration, easeStyle, easeDir),
        {Scale = 0.03}
    )
    scaleDown:Play()

    if halfwayCallback then
        task.wait(duration / 2)
        halfwayCallback()
    else
        task.wait(duration)
    end
end

