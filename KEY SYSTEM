-- ==========================================
-- LOADING PROGRESS (WITH VALUE-BASED TICKER)
-- ==========================================
task.spawn(function()
    task.wait(0.3)
    
    local Target = 0
    local Current = 0
    local LastPlayedPercent = -1 
    local SpeedModifier = 4.2
    local Start = tick()
    
    task.spawn(function()
        while true do
            local elapsed = tick() - Start
            local alpha = math.clamp(elapsed / SpeedModifier, 0, 1)
            Target = alpha * alpha * (3 - 2 * alpha) 
            if alpha >= 1 then break end
            task.wait()
        end
    end)
    
    local LoopConnection
    LoopConnection = RunService.RenderStepped:Connect(function(dt)
        local SmoothAlpha = 1 - math.exp(-12 * dt)
        Current = Current + (Target - Current) * SmoothAlpha
        
        BarActive.Size = UDim2.new(Current, 0, 1, 0)
        
        local DisplayPercent = math.floor(math.clamp(Current * 100, 0, 100))
        MiniPercentLabel.Text = DisplayPercent .. "%"
        
        if DisplayPercent ~= LastPlayedPercent and DisplayPercent <= 100 then
            LastPlayedPercent = DisplayPercent
            task.spawn(function()
                playS(TICK_PROGRESS_SOUND)
            end)
        end
        
        if Current >= 0.999 then
            Current = 1
            BarActive.Size = UDim2.new(1, 0, 1, 0)
            MiniPercentLabel.Text = "100%"
            MiniPercentLabel.TextColor3 = DarkRed
            HeaderLabel.Text = "Lᴏᴀᴅᴇᴅ !!"
            HeaderLabel.TextColor3 = DarkRed
            LoopConnection:Disconnect()
            
            blinkRunning = false
            task.wait(0.9)
            startKeySystemTransition()
        end
    end)
end)

