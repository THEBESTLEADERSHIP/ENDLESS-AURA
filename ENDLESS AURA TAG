-- Kill switch function jo next execution par sab khatam karega
local isScriptAlive = true
_G.AuraKillSwitch = function()
    isScriptAlive = false
    -- Old emitters ko clear karo
    if AuraState.emitters then
        for _, emitter in ipairs(AuraState.emitters) do
            if emitter and emitter.Parent then emitter:Destroy() end
        end
    end
    -- Old animation track ko stop karo
    if AuraState.currentTrack then
        pcall(function() AuraState.currentTrack:Stop() end)
    end
    -- Old HUD ko clear karo
    if playerGui and playerGui:FindFirstChild("AuraHUD") then
        playerGui:FindFirstChild("AuraHUD"):Destroy()
    end
    -- Character ke andar ke purane tags aur attachments hatao
    local char = player.Character
    if char then
        for _, child in ipairs(char:GetDescendants()) do
            if child.Name == "EACircle" or child.Name == "OverheadTag" or child.Name == "AuraAttachment" then
                child:Destroy()
            end
        end
    end
end

