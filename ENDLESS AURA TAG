        if part then createThunder(part, 0, 50, 4, 1.1) end
    end

    local heavyParts = {
        "LeftUpperArm", "LeftLowerArm", "LeftHand", "Left Arm",
        "RightUpperArm", "RightLowerArm", "RightHand", "Right Arm",
        "LeftUpperLeg", "LeftLowerLeg", "LeftFoot", "Left Leg",
        "RightUpperLeg", "RightLowerLeg", "RightFoot", "Right Leg"
    }
    for _, partName in ipairs(heavyParts) do
        local part = character:FindFirstChild(partName)
        if part then createThunder(part, 0, 95, 5, 1.3) end
    end

    createThunder(hrp, 0, 65, 5, 1.4)
    createThunder(hrp, 1, 45, 4, 1.0)
    createThunder(hrp, -1, 45, 4, 1.0)

    local groundAtt = Instance.new("Attachment")
    groundAtt.Position = Vector3.new(0, -3, 0)
    groundAtt.Parent = hrp

    local groundThunder = Instance.new("ParticleEmitter")
    groundThunder.Parent = groundAtt
    groundThunder.Texture = "rbxassetid://6101261905"
    groundThunder.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 40, 40)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 0, 0))
    })
    groundThunder.LightEmission = 1
    groundThunder.LightInfluence = 0
    groundThunder.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.4),
        NumberSequenceKeypoint.new(0.4, 1.4),
        NumberSequenceKeypoint.new(1, 0)
    })
    groundThunder.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.1),
        NumberSequenceKeypoint.new(1, 1)
    })
    groundThunder.Lifetime = NumberRange.new(0.4, 0.7)
    groundThunder.Rate = 75
    groundThunder.Speed = NumberRange.new(3, 6)
    groundThunder.SpreadAngle = Vector2.new(110, 110)
    groundThunder.EmissionDirection = Enum.NormalId.Bottom
    groundThunder.Enabled = AuraState.auraEnabled
    table.insert(AuraState.emitters, groundThunder)

    -- Dynamic Idle Execution Engine
    local idleAnim = Instance.new("Animation")
    idleAnim.AnimationId = "rbxassetid://138665010911335"

    local idleTrack = animator:LoadAnimation(idleAnim)
    idleTrack.Priority = Enum.AnimationPriority.Idle
    idleTrack.Looped = true
    AuraState.currentTrack = idleTrack

    humanoid.Running:Connect(function(speed)
        if speed < 0.5 then
            if AuraState.animEnabled and not idleTrack.IsPlaying then
                idleTrack:Play()
            end
        else
            if idleTrack.IsPlaying then
                idleTrack:Stop()
            end
        end
    end)

    if humanoid.MoveDirection.Magnitude < 0.1 and AuraState.animEnabled then
        idleTrack:Play()
    end
end

-- Strict Avatar Appearance Observers Connection
local function attachCharacterTracks(character)
    if not character then return end
    
    -- Baseline boot execution
    task.spawn(setup, character)
    
    -- Sub-Pipeline A: Triggers safely when clothes/assets finish streaming
    character.CharacterAppearanceLoaded:Connect(function()
        task.spawn(setup, character)
    end)
    
    -- Sub-Pipeline B: Triggers instantly if catalog avatar description modifications are injected
    local humanoid = character:WaitForChild("Humanoid", 10)
    if humanoid then
        humanoid.DescriptionApplied:Connect(function()
            task.spawn(setup, character)
        end)
    end
end

if player.Character then attachCharacterTracks(player.Character) end
player.CharacterAdded:Connect(attachCharacterTracks)
