    end)

    -- EXACT ORIGINAL 3-LAYER AURA SYSTEM
    local function createThunder(parent, offsetY, rate, speed, size)
        if not isScriptAlive or not parent or not parent.Parent then return end
        local att = Instance.new("Attachment")
        att.Name = "AuraAttachment"
        att.Position = Vector3.new(0, offsetY, 0)
