        smoke.LightInfluence = 0.5
        smoke.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 1.5),
            NumberSequenceKeypoint.new(0.5, size * 2.5),
            NumberSequenceKeypoint.new(1, size * 3.0)
        })
        smoke.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.6),
            NumberSequenceKeypoint.new(0.5, 0.8),
            NumberSequenceKeypoint.new(1, 1)
        })
        smoke.Lifetime = NumberRange.new(0.5, 1.0)
        smoke.Rate = rate * 0.4
        smoke.Speed = NumberRange.new(0.5, 1.5)
        smoke.SpreadAngle = Vector2.new(360, 360)

        table.insert(AuraState.emitters, thunder)
        table.insert(AuraState.emitters, glow)
        table.insert(AuraState.emitters, smoke)
    end

    -- Aura on body parts (original placement)
    createThunder(hrp, 0, 45, 3, 0.55)
    createThunder(hrp, -2, 30, 2, 0.4)
    createThunder(head, 0, 25, 2, 0.35)

    -- Sync emitter state
    for _, emitter in ipairs(AuraState.emitters) do
        if emitter and emitter.Parent then
            emitter.Enabled = AuraState.auraEnabled
        end
    end

    -- =====================
    -- ANIMATION (EXACT ORIGINAL)
    -- =====================
    local idleAnim = Instance.new("Animation")
    idleAnim.AnimationId = "rbxassetid://180435571"
    local track = animator:LoadAnimation(idleAnim)
    track.Looped = true
    AuraState.currentTrack = track

    humanoid.Running:Connect(function(speed)
        if not AuraState.animEnabled then return end
        if speed < 0.1 then
            track:Play()
        else
            track:Stop()
        end
    end)

    if AuraState.animEnabled then
        track:Play()
    end
end

-- Character spawn
if player.Character then
    setup(player.Character)
end
player.CharacterAdded:Connect(setup)
