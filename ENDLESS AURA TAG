        end
    end)

    if humanoid.MoveDirection.Magnitude < 0.1 and AuraState.animEnabled then
        idleTrack:Play()
    end
end

local function safeSetup(character)
    pcall(setup, character)
    syncHUD()
end

safeSetup(player.Character or player.CharacterAdded:Wait())
player.CharacterAdded:Connect(safeSetup)
