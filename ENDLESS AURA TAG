    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    frame.Parent = billboard

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(200, 0, 0)
    stroke.Thickness = 1.8
    stroke.Parent = frame

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = frame

    local eaTagLabel = Instance.new("TextLabel")
    eaTagLabel.Size = UDim2.new(0.17, 0, 1, 0)
    eaTagLabel.Position = UDim2.new(0.01, 0, 0, 0)
    eaTagLabel.BackgroundTransparency = 1
    eaTagLabel.Text = "EA"
    eaTagLabel.TextColor3 = Color3.fromRGB(200, 0, 0)
    eaTagLabel.TextScaled = true
    eaTagLabel.Font = Enum.Font.GothamBold
    eaTagLabel.Parent = frame

    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(0, 1.5, 0.7, 0)
    divider.Position = UDim2.new(0.19, 0, 0.15, 0)
    divider.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    divider.BackgroundTransparency = 0
    divider.BorderSizePixel = 0
    divider.Parent = frame

    local auraLabel = Instance.new("TextLabel")
    auraLabel.Size = UDim2.new(0.79, 0, 0.54, 0)
    auraLabel.Position = UDim2.new(0.21, 0, 0.02, 0)
    auraLabel.BackgroundTransparency = 1
    auraLabel.Text = "Eɴᴅʟᴇss Aᴜʀᴀ: Usᴇʀ"
    auraLabel.TextColor3 = Color3.fromRGB(200, 0, 0)
    auraLabel.TextScaled = true
    auraLabel.Font = Enum.Font.GothamBold
    auraLabel.TextXAlignment = Enum.TextXAlignment.Left
    auraLabel.Parent = frame

    -- Username - WHITE
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0.79, 0, 0.38, 0)
    nameLabel.Position = UDim2.new(0.21, 0, 0.57, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = "@" .. player.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = frame

    -- ===== DISTANCE CHECK + TAGS TOGGLE =====
    local distConn
    distConn = RunService.RenderStepped:Connect(function()
        if not character.Parent then
            distConn:Disconnect()
            return
        end

        if not AuraState.tagsEnabled then
            billboard.Enabled = false
            eaBillboard.Enabled = false
            return
        end

        local dist = (camera.CFrame.Position - head.Position).Magnitude
        if dist > 40 then
            billboard.Enabled = false
            eaBillboard.Enabled = true
        else
            billboard.Enabled = true
            eaBillboard.Enabled = false
        end
    end)

    -- ===== THUNDER AURA FUNCTION =====
    local function createThunder(parent, offsetY, rate, speed, size)
        local att = Instance.new("Attachment")
        att.Position = Vector3.new(0, offsetY, 0)
        att.Parent = parent

        local thunder = Instance.new("ParticleEmitter")
        thunder.Parent = att
        thunder.Texture = "rbxassetid://6101261905"
        thunder.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 50, 50)),
            ColorSequenceKeypoint.new(0.4, Color3.fromRGB(220, 0, 0)),
            ColorSequenceKeypoint.new(0.8, Color3.fromRGB(255, 100, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(120, 0, 0))
        })
        thunder.LightEmission = 1
        thunder.LightInfluence = 0
        thunder.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 0.5),
            NumberSequenceKeypoint.new(0.3, size * 1.2),
            NumberSequenceKeypoint.new(0.7, size * 0.8),
            NumberSequenceKeypoint.new(1, 0)
        })
        thunder.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(0.4, 0.2),
            NumberSequenceKeypoint.new(1, 1)
        })
        thunder.Lifetime = NumberRange.new(0.4, 0.8)
        thunder.Rate = rate
        thunder.Speed = NumberRange.new(speed, speed + 3)
        thunder.SpreadAngle = Vector2.new(90, 90)
        thunder.RotSpeed = NumberRange.new(-200, 200)
        thunder.Rotation = NumberRange.new(0, 360)
        thunder.ZOffset = 0.3

        local glow = Instance.new("ParticleEmitter")
        glow.Parent = att
        glow.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(180, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 0, 0))
        })
        glow.LightEmission = 1
        glow.LightInfluence = 0
        glow.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 1.8),
            NumberSequenceKeypoint.new(0.4, size * 1.3),
            NumberSequenceKeypoint.new(1, 0)
        })
        glow.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.3),
            NumberSequenceKeypoint.new(0.5, 0.6),
            NumberSequenceKeypoint.new(1, 1)
        })
        glow.Lifetime = NumberRange.new(0.3, 0.6)
        glow.Rate = rate * 0.8
        glow.Speed = NumberRange.new(0.5, 2)
        glow.SpreadAngle = Vector2.new(360, 360)

        local smoke = Instance.new("ParticleEmitter")
        smoke.Parent = att
        smoke.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(60, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 0, 0))
        })
        smoke.LightEmission = 0.3
        smoke.LightInfluence = 0.5
        smoke.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 0.8),
            NumberSequenceKeypoint.new(0.5, size * 2),
            NumberSequenceKeypoint.new(1, 0)
        })
        smoke.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.5),
            NumberSequenceKeypoint.new(0.6, 0.8),
            NumberSequenceKeypoint.new(1, 1)
        })
        smoke.Lifetime = NumberRange.new(0.6, 1.2)
        smoke.Rate = rate * 0.5
        smoke.Speed = NumberRange.new(1, 2.5)
        smoke.SpreadAngle = Vector2.new(40, 40)

        thunder.Enabled = AuraState.auraEnabled
        glow.Enabled = AuraState.auraEnabled
        smoke.Enabled = AuraState.auraEnabled
        table.insert(AuraState.emitters, thunder)
        table.insert(AuraState.emitters, glow)
        table.insert(AuraState.emitters, smoke)
    end

    -- ===== AURA HAR BODY PART PE =====
    local bodyParts = {
        "Head", "UpperTorso", "LowerTorso",
        "LeftUpperArm", "LeftLowerArm", "LeftHand",
        "RightUpperArm", "RightLowerArm", "RightHand",
        "LeftUpperLeg", "LeftLowerLeg", "LeftFoot",
        "RightUpperLeg", "RightLowerLeg", "RightFoot",
        "Torso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"
    }

    for _, partName in ipairs(bodyParts) do
        local part = character:FindFirstChild(partName)
        if part then
            createThunder(part, 0, 45, 4, 1.1)
        end
    end

    createThunder(hrp, 0, 60, 5, 1.4)
    createThunder(hrp, 1, 40, 4, 1.0)
    createThunder(hrp, -1, 40, 4, 1.0)

    -- Ground effect
    local groundAtt = Instance.new("Attachment")
    groundAtt.Position = Vector3.new(0, -3, 0)
    groundAtt.Parent = hrp

    local groundThunder = Instance.new("ParticleEmitter")
    groundThunder.Parent = groundAtt
    groundThunder.Texture = "rbxassetid://6101261905"
    groundThunder.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 40, 40)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 0, 0))
    })
    groundThunder.LightEmission = 1
    groundThunder.LightInfluence = 0
    groundThunder.Size = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.4),
        NumberSequenceKeypoint.new(0.4, 1.2),
        NumberSequenceKeypoint.new(1, 0)
    })
    groundThunder.Transparency = NumberSequence.new({
        NumberSequenceKeypoint.new(0, 0.1),
        NumberSequenceKeypoint.new(1, 1)
    })
    groundThunder.Lifetime = NumberRange.new(0.5, 0.9)
    groundThunder.Rate = 50
    groundThunder.Speed = NumberRange.new(2, 5)
    groundThunder.SpreadAngle = Vector2.new(100, 100)
    groundThunder.EmissionDirection = Enum.NormalId.Bottom
    groundThunder.Enabled = AuraState.auraEnabled
    table.insert(AuraState.emitters, groundThunder)

    -- ===== IDLE ANIMATION =====
    local AnimationIds = {
        Idle = 138665010911335,
    }

    local idleAnim = Instance.new("Animation")
    idleAnim.AnimationId = "rbxassetid://" .. AnimationIds.Idle

    local idleTrack = animator:LoadAnimation(idleAnim)
    idleTrack.Priority = Enum.AnimationPriority.Idle
    idleTrack.Looped = true

    humanoid.Running:Connect(function(speed)
        if speed < 0.5 then
            if not idleTrack.IsPlaying then
                idleTrack:Play()
            end
        else
            if idleTrack.IsPlaying then
                idleTrack:Stop()
            end
        end
    end)

    if humanoid.MoveDirection.Magnitude < 0.1 then
        idleTrack:Play()
    end
end

-- =====================
-- INITIAL + RESPAWN (pcall safety - kabhi crash nahi hoga)
-- =====================

local function safeSetup(character)
    local ok, err = pcall(setup, character)
    if not ok then
        warn("Aura setup error: " .. tostring(err))
    end
end

safeSetup(player.Character or player.CharacterAdded:Wait())
player.CharacterAdded:Connect(safeSetup)
