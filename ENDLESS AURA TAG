    notifStroke.Parent = notifFrame

    -- Bada Avatar Image Setup to match frame
    local avatarImg = Instance.new("ImageLabel")
    avatarImg.Size = UDim2.new(0, 46, 0, 46)
    avatarImg.Position = UDim2.new(0, 10, 0.5, -23)
    avatarImg.BackgroundTransparency = 1
    avatarImg.BorderSizePixel = 0
    avatarImg.Parent = notifFrame

    local avatarCorner = Instance.new("UICorner")
    avatarCorner.CornerRadius = UDim.new(1, 0)
    avatarCorner.Parent = avatarImg

    pcall(function()
        local userId = joinedPlayer.UserId
        avatarImg.Image = Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
    end)

    -- Large Readable Red Text Notification Label
    local txtLabel = Instance.new("TextLabel")
    txtLabel.Size = UDim2.new(1, -70, 1, 0)
    txtLabel.Position = UDim2.new(0, 66, 0, 0)
    txtLabel.BackgroundTransparency = 1
    txtLabel.Font = Enum.Font.GothamBold
    txtLabel.TextSize = 12
    txtLabel.TextColor3 = Color3.fromRGB(255, 30, 30) -- RED TEXT
    txtLabel.TextXAlignment = Enum.TextXAlignment.Left
    txtLabel.TextWrapped = true
    txtLabel.Text = "PLAYER HAS JOINED:\n@" .. joinedPlayer.Name
    txtLabel.Parent = notifFrame

    -- Dynamic Slide In Animation
    local tweenIn = TweenService:Create(notifFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Position = UDim2.new(0.5, 0, 0, 14)
    })
    tweenIn:Play()

    -- 4 Seconds display hold then slide up and destroy
    task.delay(4, function()
        if notifFrame and notifFrame.Parent then
            local tweenOut = TweenService:Create(notifFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
                Position = UDim2.new(0.5, 0, 0, -80)
            })
            tweenOut:Play()
            tweenOut.Completed:Connect(function()
                notifFrame:Destroy()
            end)
        end
    end)
end

