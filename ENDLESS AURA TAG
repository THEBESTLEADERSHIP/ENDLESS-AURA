local function attachCharacterTracks(character)
    if not isScriptAlive or not character then return end
    task.spawn(setup, character)
end

task.spawn(function()
    while isScriptAlive do
        local currentCharacter = player.Character
        if currentCharacter and currentCharacter.Parent then
            local head = currentCharacter:FindFirstChild("Head")
            if head and not head:FindFirstChild("OverheadTag") then
                task.spawn(attachCharacterTracks, currentCharacter)
            end
        end
        task.wait(1.5)
    end
end)

if player.Character then task.spawn(attachCharacterTracks, player.Character) end
player.CharacterAdded:Connect(function(char)
    task.spawn(attachCharacterTracks, char)
end)
