    -- ===== EXACT HEAVY THREE-PART AURA GENERATOR =====
    local function createThunder(parent, offsetY, rate, speed, size)
        local att = Instance.new("Attachment")
        att.Position = Vector3.new(0, offsetY, 0)
        att.Parent = parent

        -- 1. Thunder Emitter
        local thunder = Instance.new("ParticleEmitter")
        thunder.Parent = att
        thunder.Texture = "rbxassetid://6101261905"
        thunder.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 50, 50)),
            ColorSequenceKeypoint.new(0.4, Color3.fromRGB(220, 0, 0)),
            ColorSequenceKeypoint.new(0.8, Color3.fromRGB(255, 100, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(120, 0, 0))
        })
        thunder.LightEmission = 1
        thunder.LightInfluence = 0
        thunder.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 0.6),
            NumberSequenceKeypoint.new(0.3, size * 1.4),
            NumberSequenceKeypoint.new(0.7, size * 0.9),
            NumberSequenceKeypoint.new(1, 0)
        })
        thunder.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(0.4, 0.15),
            NumberSequenceKeypoint.new(1, 1)
        })
        thunder.Lifetime = NumberRange.new(0.3, 0.6)
        thunder.Rate = rate
        thunder.Speed = NumberRange.new(speed, speed + 4)
        thunder.SpreadAngle = Vector2.new(90, 90)
        thunder.RotSpeed = NumberRange.new(-250, 250)
        thunder.Rotation = NumberRange.new(0, 360)
        thunder.ZOffset = 0.4

        -- 2. Glow Emitter
        local glow = Instance.new("ParticleEmitter")
        glow.Parent = att
        glow.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(180, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 0, 0))
        })
        glow.LightEmission = 1
        glow.LightInfluence = 0
        glow.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 2.0),
            NumberSequenceKeypoint.new(0.4, size * 1.4),
            NumberSequenceKeypoint.new(1, 0)
        })
        glow.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.25),
            NumberSequenceKeypoint.new(0.5, 0.55),
            NumberSequenceKeypoint.new(1, 1)
        })
        glow.Lifetime = NumberRange.new(0.3, 0.5)
        glow.Rate = rate * 0.7
        glow.Speed = NumberRange.new(1, 2.5)
        glow.SpreadAngle = Vector2.new(360, 360)

        -- 3. Smoke Emitter
        local smoke = Instance.new("ParticleEmitter")
        smoke.Parent = att
        smoke.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(15, 0, 0))
        })
        smoke.LightEmission = 0.2
        smoke.LightInfluence = 0.5
        smoke.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 0.8),
            NumberSequenceKeypoint.new(0.5, size * 2.2),
            NumberSequenceKeypoint.new(1, 0)
        })
