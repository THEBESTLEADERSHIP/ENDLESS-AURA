local function createBox(name, text, withDot, interactive)
    local box = Instance.new("Frame")
    box.Name = name
    box.AutomaticSize = Enum.AutomaticSize.X
    box.Size = UDim2.new(0, 0, 1, -4)
    box.BackgroundColor3 = Color3.fromRGB(10, 0, 0)
    box.BackgroundTransparency = 0.2
    box.BorderSizePixel = 0
    box.Parent = bar

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 4)
    corner.Parent = box

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(180, 0, 0)
    stroke.Thickness = 1
    stroke.Parent = box

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Padding = UDim.new(0, 3)
    layout.Parent = box

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 6)
    padding.PaddingRight = UDim.new(0, 6)
    padding.Parent = box

    local dot
    if withDot then
        dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, 5, 0, 5)
        dot.BackgroundColor3 = Color3.fromRGB(0, 255, 80)
        dot.BorderSizePixel = 0
        dot.Parent = box
        local dc = Instance.new("UICorner")
        dc.CornerRadius = UDim.new(1, 0)
        dc.Parent = dot
    end

    local label
    if interactive then
        label = Instance.new("TextButton")
        label.AutoButtonColor = false
    else
        label = Instance.new("TextLabel")
    end
    label.AutomaticSize = Enum.AutomaticSize.X
    label.Size = UDim2.new(0, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(220, 30, 30)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 10
    label.Text = text
    label.Parent = box

    return box, label, dot
end

