local function createRealisticAura(character)
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    AuraState.emitters = {}
    AuraState.lights = {}

    -- PointLight in HRP (dynamic flicker)
    local mainLight = Instance.new("PointLight")
    mainLight.Color = Color3.fromRGB(255, 30, 30)
    mainLight.Brightness = 4
    mainLight.Range = 16
    mainLight.Enabled = AuraState.auraEnabled
    mainLight.Parent = hrp
    table.insert(AuraState.lights, mainLight)

    -- Flicker task
    task.spawn(function()
        while mainLight and mainLight.Parent do
            if AuraState.auraEnabled then
                mainLight.Brightness = math.random(30, 50) / 10
                mainLight.Range = math.random(13, 18)
            end
            task.wait(0.05 + math.random() * 0.07)
        end
    end)

    -- AURA LAYER FUNCTION
    -- layer = "core" | "mid" | "outer" | "ground" | "spark" | "ember"
    local function makeEmitter(att, cfg)
        local em = Instance.new("ParticleEmitter")
        em.Parent = att
        em.Texture             = cfg.tex    or "rbxassetid://6101261905"
        em.Color               = cfg.color  or ColorSequence.new(Color3.fromRGB(255, 0, 0))
        em.LightEmission       = cfg.le     or 1
        em.LightInfluence      = cfg.li     or 0
        em.Size                = cfg.size   or NumberSequence.new(1)
        em.Transparency        = cfg.trans  or NumberSequence.new(0)
        em.Lifetime            = cfg.life   or NumberRange.new(0.5, 1)
        em.Rate                = cfg.rate   or 30
        em.Speed               = cfg.speed  or NumberRange.new(1, 3)
        em.SpreadAngle         = cfg.spread or Vector2.new(180, 180)
        em.RotSpeed            = cfg.rotsp  or NumberRange.new(-180, 180)
        em.Rotation            = NumberRange.new(0, 360)
        em.ZOffset             = cfg.zoff   or 0
        em.Enabled             = AuraState.auraEnabled
        if cfg.dir then em.EmissionDirection = cfg.dir end
        if cfg.wind then em.LockedToPart = false end
        table.insert(AuraState.emitters, em)
        return em
    end

    -- Attachment helper
