        pcall(function()
            local pingValue = StatsService.Network.ServerStatsItem["Data Ping"]:GetValue()
            pingLabel.Text = "Pɪɴɢ: " .. math.floor(pingValue) .. "ᴍs"
        end)
        local dt = DateTime.now():ToLocalTime()
        local hour = dt.Hour
        local ampm = "AM"
        if hour >= 12 then ampm = "PM" if hour > 12 then hour -= 12 end end
