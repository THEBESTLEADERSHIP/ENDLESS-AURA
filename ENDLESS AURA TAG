    divider.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    divider.BorderSizePixel = 0
    divider.Parent = frame

    local auraLabel2 = Instance.new("TextLabel")
    auraLabel2.Size = UDim2.new(0.79, 0, 0.54, 0)
    auraLabel2.Position = UDim2.new(0.21, 0, 0.02, 0)
    auraLabel2.BackgroundTransparency = 1
    auraLabel2.Text = "Eɴᴅʟᴇss Aᴜʀᴀ: Usᴇʀ"
    auraLabel2.TextColor3 = Color3.fromRGB(210, 0, 0)
    auraLabel2.TextScaled = true
    auraLabel2.Font = Enum.Font.GothamBold
    auraLabel2.TextXAlignment = Enum.TextXAlignment.Left
    auraLabel2.Parent = frame

    local nameLabel2 = Instance.new("TextLabel")
    nameLabel2.Size = UDim2.new(0.79, 0, 0.38, 0)
    nameLabel2.Position = UDim2.new(0.21, 0, 0.57, 0)
    nameLabel2.BackgroundTransparency = 1
    nameLabel2.Text = "@" .. player.Name
    nameLabel2.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel2.TextScaled = true
    nameLabel2.Font = Enum.Font.Gotham
    nameLabel2.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel2.Parent = frame

    -- Distance-based tag switching
    local distConn
    distConn = RunService.RenderStepped:Connect(function()
        if not character.Parent then distConn:Disconnect() return end
        if not AuraState.tagsEnabled then
            bb.Enabled = false
            eaBB.Enabled = false
            return
        end
        local dist = (camera.CFrame.Position - head.Position).Magnitude
        bb.Enabled = dist <= 40
        eaBB.Enabled = dist > 40
    end)

    -- ===== IDLE ANIMATION =====
    local idleAnim = Instance.new("Animation")
    idleAnim.AnimationId = "rbxassetid://138665010911335"
    local idleTrack = animator:LoadAnimation(idleAnim)
    idleTrack.Priority = Enum.AnimationPriority.Idle
    idleTrack.Looped = true
    AuraState.currentTrack = idleTrack

    humanoid.Running:Connect(function(speed)
        if speed < 0.5 then
            if AuraState.animEnabled and not idleTrack.IsPlaying then idleTrack:Play() end
        else
            if idleTrack.IsPlaying then idleTrack:Stop() end
        end
    end)

    if humanoid.MoveDirection.Magnitude < 0.1 and AuraState.animEnabled then
        idleTrack:Play()
    end
end

