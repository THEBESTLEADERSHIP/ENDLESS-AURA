    groundThunder.Speed = NumberRange.new(3, 6)
    groundThunder.SpreadAngle = Vector2.new(110, 110)
    groundThunder.EmissionDirection = Enum.NormalId.Bottom
    groundThunder.Enabled = AuraState.auraEnabled
    table.insert(AuraState.emitters, groundThunder)

    -- Idle Animation Player
    local idleAnim = Instance.new("Animation")
    idleAnim.AnimationId = "rbxassetid://138665010911335"

    local idleTrack = animator:LoadAnimation(idleAnim)
    idleTrack.Priority = Enum.AnimationPriority.Idle
    idleTrack.Looped = true
    AuraState.currentTrack = idleTrack

    humanoid.Running:Connect(function(speed)
        if not isScriptAlive then return end
        if speed < 0.5 then
            if AuraState.animEnabled and not idleTrack.IsPlaying then idleTrack:Play() end
        else
            if idleTrack.IsPlaying then idleTrack:Stop() end
        end
    end)

    if humanoid.MoveDirection.Magnitude < 0.1 and AuraState.animEnabled then
        idleTrack:Play()
