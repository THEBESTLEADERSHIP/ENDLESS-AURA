local function setup(character)
    if not character or not character.Parent then return end
    
    local head = character:FindFirstChild("Head") or character:WaitForChild("Head", 10)
    local humanoid = character:FindFirstChildOfClass("Humanoid") or character:WaitForChild("Humanoid", 10)
    local hrp = character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart", 10)
    if not head or not humanoid or not hrp then return end
    local animator = humanoid:FindFirstChildOfClass("Animator") or humanoid:WaitForChild("Animator", 10)
    if not animator then return end

    -- Avoid re-running fully if elements exist
    if head:FindFirstChild("OverheadTag") and hrp:FindFirstChild("Attachment") then return end

    for _, child in ipairs(head:GetChildren()) do
        if child.Name == "EACircle" or child.Name == "OverheadTag" then child:Destroy() end
    end

    AuraState.emitters = {}

    -- ===== FULL OVERHEAD TEXT TAG =====
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "OverheadTag"
    billboard.Size = UDim2.new(0, 140, 0, 36)
    billboard.StudsOffset = Vector3.new(0, 2.9, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = math.huge
    billboard.Parent = head

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 0
    frame.Parent = billboard

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(200, 0, 0)
    stroke.Thickness = 1.8
    stroke.Parent = frame

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = frame

    local tagLogoImage = Instance.new("ImageLabel")
    tagLogoImage.Size = UDim2.new(0, 24, 0, 24)
    tagLogoImage.Position = UDim2.new(0.02, 0, 0.5, -12)
    tagLogoImage.BackgroundTransparency = 1
    tagLogoImage.Image = CUSTOM_LOGO_ID
    tagLogoImage.Parent = frame

    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(0, 1.5, 0.7, 0)
    divider.Position = UDim2.new(0.22, 0, 0.15, 0)
    divider.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    divider.BorderSizePixel = 0
    divider.Parent = frame

    local overheadAuraLabel = Instance.new("TextLabel")
    overheadAuraLabel.Size = UDim2.new(0.76, 0, 0.54, 0)
    overheadAuraLabel.Position = UDim2.new(0.24, 0, 0.02, 0)
    overheadAuraLabel.BackgroundTransparency = 1
    overheadAuraLabel.Text = "Eɴᴅʟᴇss Aᴜʀᴀ: Usᴇʀ"
    overheadAuraLabel.TextColor3 = Color3.fromRGB(200, 0, 0)
    overheadAuraLabel.TextScaled = true
    overheadAuraLabel.Font = Enum.Font.GothamBold
    overheadAuraLabel.TextXAlignment = Enum.TextXAlignment.Left
    overheadAuraLabel.Parent = frame

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(0.76, 0, 0.38, 0)
    nameLabel.Position = UDim2.new(0.24, 0, 0.57, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = "@" .. player.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = frame

    local renderConn
    local rotAngle = 0
    renderConn = RunService.RenderStepped:Connect(function(dt)
        if not character or not character.Parent or not head or not head.Parent or not billboard or not billboard.Parent then 
            renderConn:Disconnect() 
            return 
        end
        rotAngle = (rotAngle + (90 * dt)) % 360
        if tagLogoImage and tagLogoImage.Parent then tagLogoImage.Rotation = rotAngle end
        billboard.Enabled = AuraState.tagsEnabled
    end)

    -- Particle Pipeline
    local function createThunder(parent, offsetY, rate, speed, size)
        if not parent or not parent.Parent then return end
        local att = Instance.new("Attachment")
        att.Position = Vector3.new(0, offsetY, 0)
        att.Parent = parent

        local thunder = Instance.new("ParticleEmitter")
        thunder.Parent = att
        thunder.Texture = "rbxassetid://6101261905"
        thunder.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 50, 50)),
            ColorSequenceKeypoint.new(0.4, Color3.fromRGB(220, 0, 0)),
            ColorSequenceKeypoint.new(0.8, Color3.fromRGB(255, 100, 100)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(120, 0, 0))
        })
        thunder.LightEmission = 1
        thunder.Size = NumberSequence.new({
            NumberSequenceKeypoint.new(0, size * 0.6),
            NumberSequenceKeypoint.new(0.3, size * 1.4),
            NumberSequenceKeypoint.new(1, 0)
        })
        thunder.Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0),
            NumberSequenceKeypoint.new(1, 1)
        })
        thunder.Lifetime = NumberRange.new(0.3, 0.6)
        thunder.Rate = rate
        thunder.Speed = NumberRange.new(speed, speed + 4)
        thunder.SpreadAngle = Vector2.new(90, 90)
        thunder.RotSpeed = NumberRange.new(-250, 250)
        thunder.Enabled = AuraState.auraEnabled
        table.insert(AuraState.emitters, thunder)

        local glow = Instance.new("ParticleEmitter")
        glow.Parent = att
        glow.Color = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)), ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 0, 0))})
        glow.LightEmission = 1
        glow.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, size * 2.0), NumberSequenceKeypoint.new(1, 0)})
        glow.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.25), NumberSequenceKeypoint.new(1, 1)})
        glow.Lifetime = NumberRange.new(0.3, 0.5)
        glow.Rate = rate * 0.7
        glow.Speed = NumberRange.new(1, 2.5)
        glow.Enabled = AuraState.auraEnabled
        table.insert(AuraState.emitters, glow)
    end

    for _, obj in ipairs(character:GetChildren()) do
        if obj:IsA("BasePart") and obj.Name ~= "HumanoidRootPart" then
            createThunder(obj, 0, 60, 4, 1.2)
        end
    end
    createThunder(hrp, 0, 70, 5, 1.4)

    -- Dynamic Idle Animation Load
    local idleAnim = Instance.new("Animation")
    idleAnim.AnimationId = "rbxassetid://138665010911335"
    local idleTrack = animator:LoadAnimation(idleAnim)
    idleTrack.Priority = Enum.AnimationPriority.Idle
    idleTrack.Looped = true
    AuraState.currentTrack = idleTrack

    humanoid.Running:Connect(function(speed)
        if speed < 0.5 then
            if AuraState.animEnabled and not idleTrack.IsPlaying then idleTrack:Play() end
        else
            if idleTrack.IsPlaying then idleTrack:Stop() end
        end
    end)

    if humanoid.MoveDirection.Magnitude < 0.1 and AuraState.animEnabled then
        idleTrack:Play()
    end
end

