        smoke.SpreadAngle = Vector2.new(45, 45)

        thunder.Enabled = AuraState.auraEnabled
        glow.Enabled = AuraState.auraEnabled
        smoke.Enabled = AuraState.auraEnabled

        table.insert(AuraState.emitters, thunder)
        table.insert(AuraState.emitters, glow)
        table.insert(AuraState.emitters, smoke)
    end

    local baseParts = {"Head", "UpperTorso", "LowerTorso", "Torso"}
    for _, partName in ipairs(baseParts) do
