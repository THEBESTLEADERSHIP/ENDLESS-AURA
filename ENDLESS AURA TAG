-- LocalScript

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StatsService = game:GetService("Stats")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- =====================
-- SHARED STATE (respawn pe bhi yaad rahega)
-- =====================

if not _G.AuraState then
    _G.AuraState = {
        tagsEnabled = true,
        auraEnabled = true,
        emitters = {}
    }
end
local AuraState = _G.AuraState

-- =====================
-- HUD BAR (screen top-right corner, sirf ek baar banega)
-- =====================

if not playerGui:FindFirstChild("AuraHUD") then
    local hud = Instance.new("ScreenGui")
    hud.Name = "AuraHUD"
    hud.ResetOnSpawn = false
    hud.Parent = playerGui

    -- Chota cute bar - red border, black transparent
    local bar = Instance.new("Frame")
    bar.Name = "Bar"
    bar.Size = UDim2.new(0, 340, 0, 26)
    bar.AnchorPoint = Vector2.new(1, 0)
    bar.Position = UDim2.new(1, -8, 0, 8)
    bar.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    bar.BackgroundTransparency = 0.45
    bar.BorderSizePixel = 0
    bar.Parent = hud

    local barCorner = Instance.new("UICorner")
    barCorner.CornerRadius = UDim.new(0, 10)
    barCorner.Parent = bar

    local barStroke = Instance.new("UIStroke")
    barStroke.Color = Color3.fromRGB(200, 0, 0)
    barStroke.Thickness = 1.4
    barStroke.Parent = bar

    local listLayout = Instance.new("UIListLayout")
    listLayout.FillDirection = Enum.FillDirection.Horizontal
    listLayout.HorizontalAlignment = Enum.HorizontalAlignment.Right
    listLayout.VerticalAlignment = Enum.VerticalAlignment.Center
    listLayout.Padding = UDim.new(0, 4)
    listLayout.Parent = bar

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 5)
    padding.PaddingRight = UDim.new(0, 5)
    padding.Parent = bar

    -- Helper - simple box
    local function createBox(name, width)
        local box = Instance.new("Frame")
        box.Name = name
        box.Size = UDim2.new(0, width, 0, 20)
        box.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        box.BackgroundTransparency = 0.25
        box.BorderSizePixel = 0
        box.Parent = bar

        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 6)
        corner.Parent = box

        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromRGB(200, 0, 0)
        stroke.Thickness = 1
        stroke.Parent = box

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -14, 1, 0)
        label.Position = UDim2.new(0, 14, 0, 0)
        label.BackgroundTransparency = 1
        label.TextColor3 = Color3.fromRGB(210, 0, 0)
        label.TextScaled = true
        label.Font = Enum.Font.GothamBold
        label.Parent = box

        return box, label
    end

    -- Toggle box (with cute status dot)
    local function createToggleBox(name, width, text)
        local box, label = createBox(name, width)
        label.Text = text

        local dot = Instance.new("Frame")
        dot.Size = UDim2.new(0, 6, 0, 6)
        dot.Position = UDim2.new(0, 5, 0.5, -3)
        dot.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
        dot.BorderSizePixel = 0
        dot.Parent = box

        local dotCorner = Instance.new("UICorner")
        dotCorner.CornerRadius = UDim.new(1, 0)
        dotCorner.Parent = dot

        return box, label, dot
    end

    -- Tags toggle
    local tagsBox, tagsLabel, tagsDot = createToggleBox("TagsToggle", 62, "Tags")
    local tagsButton = Instance.new("TextButton")
    tagsButton.Size = UDim2.new(1, 0, 1, 0)
    tagsButton.BackgroundTransparency = 1
    tagsButton.Text = ""
    tagsButton.Parent = tagsBox

    tagsButton.MouseButton1Click:Connect(function()
        AuraState.tagsEnabled = not AuraState.tagsEnabled
        tagsDot.BackgroundColor3 = AuraState.tagsEnabled and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(120, 0, 0)
    end)

    -- Aura toggle
    local auraBox, auraLabel, auraDot = createToggleBox("AuraToggle", 62, "Aura")
    local auraButton = Instance.new("TextButton")
    auraButton.Size = UDim2.new(1, 0, 1, 0)
    auraButton.BackgroundTransparency = 1
    auraButton.Text = ""
    auraButton.Parent = auraBox

    auraButton.MouseButton1Click:Connect(function()
        AuraState.auraEnabled = not AuraState.auraEnabled
        auraDot.BackgroundColor3 = AuraState.auraEnabled and Color3.fromRGB(0, 255, 100) or Color3.fromRGB(120, 0, 0)
        for _, emitter in ipairs(AuraState.emitters) do
            if emitter and emitter.Parent then
                emitter.Enabled = AuraState.auraEnabled
            end
        end
    end)

    -- FPS
    local fpsBox, fpsLabel = createBox("FPS", 50)
    fpsLabel.Position = UDim2.new(0, 0, 0, 0)
    fpsLabel.Size = UDim2.new(1, 0, 1, 0)
    fpsLabel.Text = "FPS: --"

    -- Ping
    local pingBox, pingLabel = createBox("Ping", 58)
    pingLabel.Position = UDim2.new(0, 0, 0, 0)
    pingLabel.Size = UDim2.new(1, 0, 1, 0)
    pingLabel.Text = "Ping: --"

    -- Time
    local timeBox, timeLabel = createBox("Time", 74)
    timeLabel.Position = UDim2.new(0, 0, 0, 0)
    timeLabel.Size = UDim2.new(1, 0, 1, 0)
    timeLabel.Text = "--:--"

    -- FPS live update
    RunService.Heartbeat:Connect(function(dt)
        if dt > 0 then
            fpsLabel.Text = "FPS: " .. math.floor(1 / dt)
        end
    end)

    -- Ping + Time live update
    task.spawn(function()
        while true do
            local ok, pingValue = pcall(function()
                return StatsService.Network.ServerStatsItem["Data Ping"]:GetValue()
            end)
            if ok then
                pingLabel.Text = "Ping: " .. math.floor(pingValue) .. "ms"
            end

            local dt = DateTime.now():ToLocalTime()
            local hour = dt.Hour
            local ampm = "AM"
            if hour >= 12 then
                ampm = "PM"
                if hour > 12 then hour -= 12 end
            end
            if hour == 0 then hour = 12 end
            timeLabel.Text = string.format("%02d:%02d %s", hour, dt.Minute, ampm)

            task.wait(1)
        end
    end)
end

-- =====================
-- CHARACTER SETUP (Tag + Aura)
-- =====================

local function setup(character)
    local head = character:WaitForChild("Head")
    local humanoid = character:WaitForChild("Humanoid")
    local animator = humanoid:WaitForChild("Animator")
    local hrp = character:WaitForChild("HumanoidRootPart")
    local camera = workspace.CurrentCamera

    for i = #AuraState.emitters, 1, -1 do
        if not AuraState.emitters[i].Parent then
            table.remove(AuraState.emitters, i)
        end
    end

    -- ===== EA CIRCLE (zoom out) =====
    local eaBillboard = Instance.new("BillboardGui")
    eaBillboard.Name = "EACircle"
    eaBillboard.Size = UDim2.new(0, 28, 0, 28)
    eaBillboard.StudsOffset = Vector3.new(0, 2.4, 0)
    eaBillboard.AlwaysOnTop = true
    eaBillboard.MaxDistance = 1000
    eaBillboard.Parent = head

    local eaCircle = Instance.new("Frame")
    eaCircle.Size = UDim2.new(1, 0, 1, 0)
    eaCircle.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    eaCircle.BackgroundTransparency = 0.5
    eaCircle.BorderSizePixel = 0
    eaCircle.Parent = eaBillboard

    local eaCircleCorner = Instance.new("UICorner")
    eaCircleCorner.CornerRadius = UDim.new(1, 0)
    eaCircleCorner.Parent = eaCircle

    local eaCircleStroke = Instance.new("UIStroke")
    eaCircleStroke.Color = Color3.fromRGB(200, 0, 0)
    eaCircleStroke.Thickness = 2
    eaCircleStroke.Parent = eaCircle

    local eaText = Instance.new("TextLabel")
    eaText.Size = UDim2.new(1, 0, 1, 0)
    eaText.BackgroundTransparency = 1
    eaText.Text = "EA"
    eaText.TextColor3 = Color3.fromRGB(200, 0, 0)
    eaText.TextScaled = true
    eaText.Font = Enum.Font.GothamBold
    eaText.Parent = eaCircle

    -- ===== PURA TAG (zoom in) =====
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "OverheadTag"
    billboard.Size = UDim2.new(0, 140, 0, 36)
    billboard.StudsOffset = Vector3.new(0, 2.9, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 1000
    billboard.Parent = head

    local frame = Instance.new("Frame")
