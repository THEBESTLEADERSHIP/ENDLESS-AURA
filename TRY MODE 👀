local function clearMyTracks()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    for _, track in pairs(hum:GetPlayingAnimationTracks()) do
        track:Stop()
    end
    myAnimationTracks = {}
end

local function getTarget()
    if not targetPlayer then return nil end
    return targetPlayer
end

local function copyAnimationTrack(targetTrack, myHum)
    local animId = targetTrack.Animation.AnimationId
    if not animId or animId == "" then return nil end
    
    local newAnim = Instance.new("Animation")
    newAnim.AnimationId = animId
    local newTrack = myHum:LoadAnimation(newAnim)
    
    newTrack.Priority = Enum.AnimationPriority.Action4
    newTrack.TimePosition = targetTrack.TimePosition
    
    if targetTrack.Speed and targetTrack.Speed ~= 1 then
        newTrack:AdjustSpeed(targetTrack.Speed)
    end
    
    return newTrack
end

local function copyAnimations()
    local target = getTarget()
    if not target then return end
    local tChar = target.Character
    local myChar = player.Character
    if not tChar or not myChar then return end
    local tHum = tChar:FindFirstChildOfClass("Humanoid")
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    if not tHum or not myHum then return end
    
    clearMyTracks()
    currentTracks = {}
    myAnimationTracks = {}
    
    local targetTracks = tHum:GetPlayingAnimationTracks()
    for _, track in pairs(targetTracks) do
        if track.WeightCurrent > 0.1 then
            local newTrack = copyAnimationTrack(track, myHum)
            if newTrack then
                newTrack:Play()
                table.insert(myAnimationTracks, newTrack)
                table.insert(currentTracks, {
                    targetTrack = track,
                    myTrack = newTrack,
                    animId = track.Animation.AnimationId
                })
            end
        end
    end
end

local function updateCopyLoop()
    if not copyNinjaActive then return end
    local target = getTarget()
    if not target then return end
    local tChar = target.Character
    local myChar = player.Character
    if not tChar or not myChar then return end
    local tHum = tChar:FindFirstChildOfClass("Humanoid")
    local myHum = myChar:FindFirstChildOfClass("Humanoid")
    if not tHum or not myHum then return end
    
    local currentAnimIds = {}
    local targetTracks = {}
    
    for _, track in pairs(tHum:GetPlayingAnimationTracks()) do
        if track.WeightCurrent > 0.1 then
            local id = track.Animation.AnimationId
            if id and id ~= "" then
                currentAnimIds[id] = true
                table.insert(targetTracks, track)
            end
        end
    end
    
    for i = #currentTracks, 1, -1 do
        local ct = currentTracks[i]
        if not currentAnimIds[ct.animId] then
            if ct.myTrack then ct.myTrack:Stop() end
            table.remove(currentTracks, i)
        end
    end
    
    for _, targetTrack in pairs(targetTracks) do
        local id = targetTrack.Animation.AnimationId
        local found = false
        
        for _, ct in pairs(currentTracks) do
            if ct.animId == id then
                found = true
                if ct.myTrack then
                    ct.myTrack.TimePosition = targetTrack.TimePosition
                    if not ct.myTrack.IsPlaying then ct.myTrack:Play() end
                end
                break
            end
        end
        
        if not found then
            local newTrack = copyAnimationTrack(targetTrack, myHum)
            if newTrack then
                newTrack:Play()
                table.insert(currentTracks, {
                    targetTrack = targetTrack,
                    myTrack = newTrack,
                    animId = id
                })
                table.insert(myAnimationTracks, newTrack)
            end
        end
    end
end

local function startCopyLoop()
    if copyLoopConnection then copyLoopConnection:Disconnect() end
    copyLoopConnection = RunService.RenderStepped:Connect(updateCopyLoop)
end

local function stopCopyLoop()
    if copyLoopConnection then copyLoopConnection:Disconnect(); copyLoopConnection = nil end
    copyNinjaActive = false
    targetPlayer = nil
    clearMyTracks()
    currentTracks = {}
end

