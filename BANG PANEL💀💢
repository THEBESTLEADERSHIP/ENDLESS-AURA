                local basePartForRotation = targetHead or targetHRP
                targetCFrame = basePartForRotation.CFrame 
                    * CFrame.new(0, fixedUpOffset, -attachDistance - dynamicOffset - 0.2) 
                    * CFrame.Angles(0, math.pi, 0)
                    + basePartForRotation.CFrame.LookVector * (sineWave * 0.7)
            else
                targetCFrame = targetHRP.CFrame 
                    * CFrame.new(0, 0, attachDistance + dynamicOffset + 0.8 + sineWave) 
                    * CFrame.Angles(tiltAngle + math.rad(sineWave * 15), 0, 0)
            end
            
            myHRP.CFrame = targetCFrame
            bg.CFrame = targetCFrame
            bv.Velocity = (targetCFrame.Position - myHRP.Position) * 120 
            
            if platform and platform.Parent then
                platform.CFrame = targetCFrame * CFrame.new(0, -3.1, 0)
            end
            
            pcall(function()
                local torso = myChar:FindFirstChild("Torso") or myChar:FindFirstChild("LowerTorso")
                local rootJoint = torso and (torso:FindFirstChild("RootJoint") or myHRP:FindFirstChild("RootJoint"))
                if rootJoint then
                    local hipThrustAngle = math.rad(sineWave * (forwardBackRange * 15))
                    local jointOffsetZ = -absSine * (forwardBackRange * 0.2)
                    rootJoint.C0 = CFrame.new(0, 0, jointOffsetZ) * CFrame.Angles((currentModeToRun == "Face Bang" and hipThrustAngle or -hipThrustAngle), 0, 0)
                end
            end)
            
            pcall(function()
                for _, v in pairs(myChar:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end)
        end) 
    end 
end)
