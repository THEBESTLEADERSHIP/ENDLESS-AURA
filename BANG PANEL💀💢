local function updateList() 
    for _, child in pairs(scrollingFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end 
    for _, p in pairs(Players:GetPlayers()) do 
        if p ~= player and (string.find(p.Name:lower(), textBox.Text:lower()) or string.find(p.DisplayName:lower(), textBox.Text:lower())) then 
            local btn = Instance.new("TextButton") 
            btn.Size = UDim2.new(1, 0, 0, 22) 
            btn.Text = " > " .. p.DisplayName .. " (@" .. p.Name .. ")"
            btn.BackgroundColor3 = table.find(selectedPlayers, p) and Color3.fromRGB(0, 100, 50) or Color3.fromRGB(15, 15, 15) 
            btn.BackgroundTransparency = 0.5
            btn.TextColor3 = table.find(selectedPlayers, p) and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(200, 200, 200) 
            btn.TextSize = 11
            btn.Font = Enum.Font.RobotoMono
            btn.TextXAlignment = Enum.TextXAlignment.Left 
            btn.BorderColor3 = Color3.fromRGB(40, 0, 10)
            btn.Parent = scrollingFrame 
            
            btn.MouseButton1Click:Connect(function() 
                local index = table.find(selectedPlayers, p)
                if index then
                    table.remove(selectedPlayers, index)
                    btn.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
                    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
                else
                    table.insert(selectedPlayers, p)
                    btn.BackgroundColor3 = Color3.fromRGB(0, 100, 50)
                    btn.TextColor3 = Color3.fromRGB(0, 255, 150)
                end
                
                if #selectedPlayers > 0 then
                    textBox.Text = "Targets Selected: " .. tostring(#selectedPlayers)
                else
                    textBox.Text = ""
                end
            end) 
        end 
    end 
end 
