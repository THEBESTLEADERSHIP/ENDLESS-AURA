            local myHumanoid = myChar and myChar:FindFirstChild("Humanoid")
            if not myHRP or not myHumanoid or not bv or not bg then return end
            
            local targetHRP = selectedPlayer.Character:FindFirstChild("HumanoidRootPart")
            local targetHead = selectedPlayer.Character:FindFirstChild("Head") 
            if not targetHRP then return end

            local currentModeToRun = targetMode
            if targetMode == "Auto Switch" then
                if tick() - lastSwitchTime >= 1.0 then
                    lastSwitchTime = tick()
                    currentAutoSubMode = (currentAutoSubMode == "Normal") and "Face Bang" or "Normal"
                end
                currentModeToRun = currentAutoSubMode
            end
            
            handleAudioForMode(targetMode)

            if targetHRP.Position.Y < -60 or targetHRP.Position.Y < (game.Workspace.FallenPartsDestroyHeight + 15) then
                bv.Velocity = Vector3.new(0,0,0)
                if platform and platform.Parent then platform.CFrame = myHRP.CFrame * CFrame.new(0, -3.1, 0) end
                return 
            end

            myHumanoid.PlatformStand = true 
            
            local timeFactor = tick() * speedMultiplier
            local sineWave = math.sin(timeFactor)
            local absSine = math.abs(sineWave)
            
            local dynamicOffset = absSine * forwardBackRange 
            local tiltAngle = -sineWave * 0.15 

            local targetCFrame
            if currentModeToRun == "Face Bang" then
                local basePartForRotation = targetHead or targetHRP
                targetCFrame = basePartForRotation.CFrame 
                    * CFrame.new(0, fixedUpOffset, -attachDistance - dynamicOffset - 0.2) 
                    * CFrame.Angles(0, math.pi, 0)
                    + basePartForRotation.CFrame.LookVector * (sineWave * 0.7)
            else
                targetCFrame = targetHRP.CFrame 
                    * CFrame.new(0, 0, attachDistance + dynamicOffset + 0.8 + sineWave) 
                    * CFrame.Angles(tiltAngle + math.rad(sineWave * 15), 0, 0)
            end
            
            -- INSTANT GLUED CONNECTION POSITION MATRIX (ZERO DELAY LATENCY LOCK)
            myHRP.CFrame = targetCFrame
            bg.CFrame = targetCFrame
            bv.Velocity = (targetCFrame.Position - myHRP.Position) * 400 
            
            if platform and platform.Parent then
                platform.CFrame = targetCFrame * CFrame.new(0, -3.1, 0)
            end
            
            pcall(function()
                local torso = myChar:FindFirstChild("Torso") or myChar:FindFirstChild("LowerTorso")
                local rootJoint = torso and (torso:FindFirstChild("RootJoint") or myHRP:FindFirstChild("RootJoint"))
                if rootJoint then
                    local hipThrustAngle = math.rad(sineWave * (forwardBackRange * 15))
                    local jointOffsetZ = -absSine * (forwardBackRange * 0.2)
                    rootJoint.C0 = CFrame.new(0, 0, jointOffsetZ) * CFrame.Angles((currentModeToRun == "Face Bang" and hipThrustAngle or -hipThrustAngle), 0, 0)
                end
            end)
            
            pcall(function()
                for _, v in pairs(myChar:GetDescendants()) do
                    if v:IsA("BasePart") then v.CanCollide = false end
                end
            end)
        end) 
    end 
end)
