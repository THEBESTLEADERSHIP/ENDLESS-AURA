-- SLIDER GENERATOR
local function createSlider(minY, labelText, minVal, maxVal, defaultVal, callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -16, 0, 14)
    label.Position = UDim2.new(0, 8, 0, minY)
    label.Text = "SYS_" .. labelText .. ":: " .. tostring(defaultVal)
    label.TextColor3 = Color3.fromRGB(180, 180, 180)
    label.Font = Enum.Font.Code
    label.TextSize = 10
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = mainFrame

    local track = Instance.new("TextButton") 
    track.Size = UDim2.new(1, -16, 0, 4)
    track.Position = UDim2.new(0, 8, 0, minY + 15)
    track.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    track.Text = ""
    track.AutoButtonColor = false
    track.BorderSizePixel = 0
    track.Parent = mainFrame

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((defaultVal - minVal)/(maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 0, 50)
    fill.BorderSizePixel = 0
    fill.Parent = track

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 8, 0, 10)
    knob.Position = UDim2.new((defaultVal - minVal)/(maxVal - minVal), -4, 0.5, -5)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.Parent = track

    local function updateSliderPosition(inputPositionX)
        local relativeX = math.clamp((inputPositionX - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        knob.Position = UDim2.new(relativeX, -4, 0.5, -5)
        fill.Size = UDim2.new(relativeX, 0, 1, 0)
        
        local currentVal = math.floor((minVal + (relativeX * (maxVal - minVal))) * 10) / 10
        label.Text = "SYS_" .. labelText .. ":: " .. tostring(currentVal)
        callback(currentVal)
    end

    local sliderDragging = false
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            sliderDragging = true
            updateSliderPosition(input.Position.X) 
        end
    end)
    userInputService.InputChanged:Connect(function(input)
        if sliderDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSliderPosition(input.Position.X)
        end
    end)
    userInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then sliderDragging = false end
    end)
end

