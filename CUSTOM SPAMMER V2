local isSpamming = false

local function executeChat(msg)
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local targetChannel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
        if targetChannel then targetChannel:SendAsync(msg) end
    else
        local chatEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
        if chatEvent then chatEvent:FireServer(msg, "All") end
    end
end

local function generatePatternString(patternUnit, maxLen)
    local result = ""
    local unitLen = string.len(patternUnit)
    if unitLen == 0 then return "" end
    while (string.len(result) + unitLen) <= maxLen do
        result = result .. patternUnit
    end
    return result
end

local function buildSpamString(sender, target, rawWord, patternUnit)
    local prefix = "SCRIPT BY " .. sender .. " > "
    local suffix = " [ " .. target .. " ] TMX MI " .. rawWord
    local staticLength = string.len(prefix) + string.len(suffix)
    local maxAllowedPatternLength = 195 - staticLength
    
    if maxAllowedPatternLength < 0 then
        return string.sub(prefix .. suffix, 1, 195)
    end
    
    local dynamicPattern = generatePatternString(patternUnit, maxAllowedPatternLength)
    return string.sub(prefix .. dynamicPattern .. suffix, 1, 195)
end

StartBtn.MouseButton1Click:Connect(function()
    playTapSound()
    isSpamming = not isSpamming
    
    if isSpamming then
        StartBtn.Text = "STOP SPAM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        StartBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        task.spawn(function()
            while isSpamming do
                local senderName = SenderBox.Text ~= "" and SenderBox.Text or "ME"
                local targetName = TargetBox.Text ~= "" and TargetBox.Text or "NOOB"
                local speed = tonumber(DelayBox.Text) or 0.5
                
                local selectedWord = SpamWords[math.random(1, #SpamWords)]
                
                -- Sequential line-by-line pattern selection
                local selectedPattern
                if useSequentialPatterns then
                    selectedPattern = CurrentPatternPool[currentPatternIndex]
                    currentPatternIndex = currentPatternIndex + 1
                    if currentPatternIndex > #CurrentPatternPool then
                        currentPatternIndex = 1
                    end
                else
                    selectedPattern = CurrentPatternPool[1]
                end
                
                local processedPayload = buildSpamString(senderName, targetName, selectedWord, selectedPattern)
                executeChat(processedPayload)
                
                task.wait(speed)
            end
        end)
    else
        StartBtn.Text = "START SPAM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        StartBtn.TextColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

