local function executeChat(msg)
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local targetChannel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
        if targetChannel then targetChannel:SendAsync(msg) end
    else
        local chatEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
        if chatEvent then chatEvent:FireServer(msg, "All") end
    end
end

local function generatePatternString(patternUnit, maxLen)
    local result = ""
    local unitLen = string.len(patternUnit)
    if unitLen == 0 then return "" end
    while (string.len(result) + unitLen) <= maxLen do
        result = result .. patternUnit
    end
    return result
end

local function buildSpamString(sender, target, rawWord, patternUnit)
    local part1 = "SCRIPT BY " .. sender .. " "
    local part2 = target .. " TMX ME " .. rawWord .. " "
    
    local staticLength = string.len(part1) + string.len(part2)
    local availableSpace = 195 - staticLength
    
    if availableSpace <= 0 then
        return string.sub(part1 .. part2, 1, 195)
    end
    
    local segmentLen = math.floor(availableSpace / 2)
    
    local leftPattern = generatePatternString(patternUnit, segmentLen)
    local rightPattern = generatePatternString(patternUnit, availableSpace - string.len(leftPattern))
    
    local combinedPayload = part1 .. leftPattern .. part2 .. rightPattern
    return string.sub(combinedPayload, 1, 195)
end

