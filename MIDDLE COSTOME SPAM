local isSpamming = false

local function executeChat(msg)
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local targetChannel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
        if targetChannel then targetChannel:SendAsync(msg) end
    else
        local chatEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
        if chatEvent then chatEvent:FireServer(msg, "All") end
    end
end

local function buildSpamString(sender, target, rawWord)
    local baseStart = "SCRIPT BY " .. sender .. " "
    local baseMiddle = " [" .. target .. "] TMX ME " .. rawWord .. " "
    
    local combinedStaticLen = string.len(baseStart) + string.len(baseMiddle)
    local freeSpace = 200 - combinedStaticLen
    
    if freeSpace <= 0 then
        return string.sub(baseStart .. baseMiddle, 1, 200)
    end
    
    -- Balanced backtick ratio allocation to preserve exact template feel
    local leftCount = math.floor(freeSpace / 2)
    local rightCount = freeSpace - leftCount
    
    local leftTicks = string.rep("`", leftCount)
    local rightTicks = string.rep("`", rightCount)
    
    return baseStart .. leftTicks .. baseMiddle .. rightTicks
end

StartBtn.MouseButton1Click:Connect(function()
    playTapSound()
    isSpamming = not isSpamming
    
    if isSpamming then
        StartBtn.Text = "STOP SPAM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        StartBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        task.spawn(function()
            local wordIndex = 1 -- Start from the first word
            while isSpamming do
                local senderName = SenderBox.Text ~= "" and SenderBox.Text or "💀NAMELESS × BHUMIKA🎀"
                local targetName = TargetBox.Text ~= "" and TargetBox.Text or "RND EMPIRE😂"
                local speed = tonumber(DelayBox.Text) or 3
                
                -- Get word sequentially
                local selectedWord = SpamWords[wordIndex]
                
                -- Move to next index or loop back to 1
                wordIndex = wordIndex + 1
                if wordIndex > #SpamWords then
                    wordIndex = 1
                end
                
                local processedPayload = buildSpamString(senderName, targetName, selectedWord)
                executeChat(processedPayload)
                
                task.wait(speed)
            end
        end)
    else
        StartBtn.Text = "START SPAM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        StartBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    end
end)

