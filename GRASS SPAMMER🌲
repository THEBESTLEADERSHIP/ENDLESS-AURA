-- Global Balanced Audio Setup with 0.50 Second Force-Cut Debounce
local isSoundPlaying = false
local function playTapSound()
    if isSoundPlaying then return end
    isSoundPlaying = true
    
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://117477686124708"
    sound.Volume = 2.5
    sound.PlaybackSpeed = 1
    sound.Parent = SoundService
    sound:Play()
    
    -- Strict execution window cutoff at exactly 0.50 seconds
    task.delay(0.50, function()
        sound:Stop()
        sound:Destroy()
        isSoundPlaying = false
    end)
end

