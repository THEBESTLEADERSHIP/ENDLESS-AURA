-- [[ Endless Aura - Anti-Void Toggle System (Compact UI) ]] --

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Workspace = game:GetService("Workspace")
local SoundService = game:GetService("SoundService")
local LocalPlayer = Players.LocalPlayer

local SOUND_ID = "rbxassetid://105571074253435"
local CORE_TAG = "EA_VoidFreedom_Engine"

-- ========================================================
-- 1. ABSOLUTE CLEANUP FUNCTION (Turn OFF Everything)
-- ========================================================
local function turnOffEverything()
    if _G[CORE_TAG] then
        _G[CORE_TAG]:Disconnect()
        _G[CORE_TAG] = nil
    end

    for _, ui in pairs(LocalPlayer:WaitForChild("PlayerGui"):GetChildren()) do
        if ui.Name == "EATempVoidUI" then 
            ui:Destroy() 
        end
    end

    for _, snd in pairs(SoundService:GetChildren()) do
        if snd.Name == "EALocalVoidSound" then
            snd:Stop()
            snd:Destroy()
        end
    end

    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then 
            hum:SetStateEnabled(Enum.HumanoidStateType.Dead, true)
            hum.MaxHealth = 100
            hum.Health = 100
        end
        
        for _, item in pairs(char:GetDescendants()) do
            if item.Name == "EAPerfectShield" or item.Name == "EAShieldAttachment" or item.Name == "EAMovementForce" then
                item:Destroy()
            end
        end
    end

    pcall(function() Workspace.FallenPartsDestroyHeight = -500 end)
end

-- ========================================================
-- 2. TOGGLE CHECK (ON / OFF Logic)
-- ========================================================
if _G.AntiVoidActive == true then
    _G.AntiVoidActive = false
    turnOffEverything()
    print("Endless Aura Anti-Void: [STATUS - OFF]")
    return 
else
    _G.AntiVoidActive = true
    print("Endless Aura Anti-Void: [STATUS - ON]")
end

-- ========================================================
-- 3. CORE ENGINE
-- ========================================================
pcall(function() Workspace.FallenPartsDestroyHeight = -999999999999 end)

local shieldActive = false
local uiTriggered = false

local function playClientSound()
    local localSound = Instance.new("Sound")
    localSound.Name = "EALocalVoidSound"
    localSound.SoundId = SOUND_ID
    localSound.Volume = 3.5
    localSound.Parent = SoundService
    localSound:Play()
    localSound.Ended:Connect(function() localSound:Destroy() end)
end

local function showVoidText()
    if uiTriggered then return end
    uiTriggered = true

    local gui = Instance.new("ScreenGui", LocalPlayer.PlayerGui)
    gui.Name = "EATempVoidUI"
    
    local lbl = Instance.new("TextLabel", gui)
    lbl.Size = UDim2.new(0, 400, 0, 70)
    lbl.Position = UDim2.new(0.5, -200, 0.75, 0) -- Center se thoda niche down
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(255, 0, 0)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 38 -- Yahan size chota kiya hai (55 se 38)
    lbl.Text = "Aɴᴛɪ Vᴏɪᴅ"
    lbl.TextTransparency = 0

    local stroke = Instance.new("UIStroke", lbl)
    stroke.Color = Color3.fromRGB(0, 0, 0)
    stroke.Thickness = 4.5 -- Stroke thickness bhi thodi adjust ki hai compact look ke liye

    task.delay(2, function()
        local tween = TweenService:Create(lbl, TweenInfo.new(0.4), {TextTransparency = 1})
        tween:Play()
        tween.Completed:Connect(function() gui:Destroy() end)
    end)
end

local function spawnShield(char)
    if shieldActive or char:FindFirstChild("EAPerfectShield") then return end
    shieldActive = true
    
    local root = char:WaitForChild("HumanoidRootPart")
    local shield = Instance.new("Part", char)
    shield.Name = "EAPerfectShield"
    shield.Shape = Enum.PartType.Ball
    shield.Size = Vector3.new(16, 16, 16)
    shield.Material = Enum.Material.ForceField
    shield.Color = Color3.fromRGB(255, 0, 0)
    shield.Transparency = 0.15
    shield.CanCollide = false
    shield.Massless = true
    shield.CFrame = root.CFrame

    local a0 = Instance.new("Attachment", root)
    a0.Name = "EAShieldAttachment"
    local a1 = Instance.new("Attachment", shield)
    
    local rigid = Instance.new("RigidConstraint", shield)
    rigid.Attachment0 = a0
    rigid.Attachment1 = a1
    
    playClientSound()
end

local function removeShield(char)
    shieldActive = false
    uiTriggered = false
    for _, item in pairs(char:GetDescendants()) do
        if item.Name == "EAPerfectShield" or item.Name == "EAShieldAttachment" or item.Name == "EAMovementForce" then
            item:Destroy()
        end
    end
end

_G[CORE_TAG] = RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    local root = char:FindFirstChild("HumanoidRootPart")
    
    if hum and root then
        if hum.Health < 1000000 then
            hum.MaxHealth = 999999999
            hum.Health = 999999999
        end
        hum:SetStateEnabled(Enum.HumanoidStateType.Dead, false)

        if root.Position.Y < -50 then
            showVoidText()
            spawnShield(char)
            
            if not root:FindFirstChild("EAMovementForce") then
                local bodyVelocity = Instance.new("BodyVelocity")
                bodyVelocity.Name = "EAMovementForce"
                bodyVelocity.MaxForce = Vector3.new(400000, 0, 400000)
                bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                bodyVelocity.Parent = root
            end
            
            local force = root:FindFirstChild("EAMovementForce")
            if force then
                force.Velocity = hum.MoveDirection * hum.WalkSpeed
            end
            
            hum:ChangeState(Enum.HumanoidStateType.Running) 
        else
            if shieldActive then
                removeShield(char)
            end
        end
    end
end)
