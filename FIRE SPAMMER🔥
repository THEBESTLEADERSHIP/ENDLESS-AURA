-- Global Balanced Audio Setup with 0.50 Second Debounce Rule
local isSoundPlaying = false
local function playTapSound()
    if isSoundPlaying then return end
    isSoundPlaying = true
    
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://106130293542098"
    sound.Volume = 2.5
    sound.PlaybackSpeed = 1
    sound.Parent = SoundService
    sound:Play()
    
    -- Force stop exactly at 0.50 seconds
    task.delay(0.50, function()
        sound:Stop()
        sound:Destroy()
        isSoundPlaying = false
    end)
end

