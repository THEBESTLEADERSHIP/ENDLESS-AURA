local isSpamming = false

-- Chat Communication Wrapper
local function executeChat(msg)
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local targetChannel = TextChatService.TextChannels:FindFirstChild("RBXGeneral")
        if targetChannel then targetChannel:SendAsync(msg) end
    else
        local chatEvent = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
        if chatEvent then chatEvent:FireServer(msg, "All") end
    end
end

-- Configured Header Strings
local baseTitle = "BY NAMELESS GORZILLA SPAMMER🐍 "
local baseAtList = "@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@@ "

-- Balanced Payload Builder protecting Max 200 Word Limit
local function buildSpamString(clanTarget, phrase)
    local targetSegment = clanTarget ~= "" and clanTarget .. " " or ""
    
    -- Calculate length without the @ characters first
    local staticLength = string.len(baseTitle) + string.len(targetSegment) + string.len(phrase)
    local availableAtSpace = 200 - staticLength
    
    local finalAtString = ""
    if availableAtSpace > 0 then
        local optimalAtCount = math.min(string.len(baseAtList), availableAtSpace)
        finalAtString = string.sub(baseAtList, 1, optimalAtCount)
    end
    
    local combinedMessage = baseTitle .. finalAtString .. targetSegment .. phrase
    
    -- Strict cutoff fallback wrapper
    if string.len(combinedMessage) > 200 then
        return string.sub(combinedMessage, 1, 200)
    else
        return combinedMessage
    end
end

StartBtn.MouseButton1Click:Connect(function()
    isSpamming = not isSpamming
    
    if isSpamming then
        StartBtn.Text = "STOP SPAM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        StartBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        
        -- Starts cleanly with zero visual flashes or execution sounds
        task.spawn(function()
            local phraseIndex = 1
            while isSpamming do
                local targetClan = TargetBox.Text
                local selectedPhrase = BaseList[phraseIndex]
                
                phraseIndex = phraseIndex + 1
                if phraseIndex > #BaseList then
                    phraseIndex = 1
                end
                
                -- Build payload sequentially under 200 limits
                local completePayload = buildSpamString(targetClan, selectedPhrase)
                executeChat(completePayload)
                
                local speed = tonumber(DelayBox.Text) or 3
                task.wait(speed)
            end
        end)
    else
        StartBtn.Text = "START SPAM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 50)
        StartBtn.TextColor3 = Color3.fromRGB(0, 0, 0)
    end
end)

